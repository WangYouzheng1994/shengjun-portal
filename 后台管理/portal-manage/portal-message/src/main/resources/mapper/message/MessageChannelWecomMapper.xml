<mapper namespace="com.raisetech.message.mapper.MessageChannelWecomMapper">
    <resultMap type="com.raisetech.message.domain.config.PortalMessageChannelWecom" id="WecomResult">
        <result property="configId" column="config_id"/>
        <result property="channelId" column="channel_id"/>
        <result property="wecomType" column="wecom_type"/>
        <result property="corpId" column="corp_id"/>
        <result property="agentId" column="agent_id"/>
        <result property="agentSecret" column="agent_secret"/>
        <result property="webhookUrl" column="webhook_url"/>
        <result property="delFlag" column="del_flag"/>
