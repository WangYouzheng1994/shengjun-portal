<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.raisetech.portal.mapper.PortalCustomerTagMapper">

    <resultMap type="com.raisetech.portal.domain.PortalCustomerTag" id="PortalCustomerTagResult">
        <result property="tagId"       column="tag_id"        />
        <result property="tagName"     column="tag_name"      />
        <result property="tagColor"    column="tag_color"     />
        <result property="sortOrder"   column="sort_order"    />
        <result property="status"      column="status"        />
        <result property="delFlag"     column="del_flag"      />
        <result property="createBy"    column="create_by"     />
        <result property="createTime"  column="create_time"   />
        <result property="updateBy"    column="update_by"     />
        <result property="updateTime"  column="update_time"   />
        <result property="remark"      column="remark"        />
    </resultMap>

    <sql id="selectPortalCustomerTagVo">
        select tag_id, tag_name, tag_color, sort_order, status,
               del_flag, create_by, create_time, update_by, update_time, remark
        from portal_customer_tag
    </sql>

    <select id="selectPortalCustomerTagList" parameterType="com.raisetech.portal.domain.PortalCustomerTag" resultMap="PortalCustomerTagResult">
        <include refid="selectPortalCustomerTagVo"/>
        <where>
            del_flag = '0'
            <if test="tagName != null and tagName != ''">
                and tag_name like concat('%', #{tagName}, '%')
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by sort_order asc
    </select>

    <select id="selectPortalCustomerTagByTagId" parameterType="Long" resultMap="PortalCustomerTagResult">
        <include refid="selectPortalCustomerTagVo"/>
        where tag_id = #{tagId} and del_flag = '0'
    </select>

    <insert id="insertPortalCustomerTag" parameterType="com.raisetech.portal.domain.PortalCustomerTag" useGeneratedKeys="true" keyProperty="tagId">
        insert into portal_customer_tag
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="tagName != null and tagName != ''">tag_name,</if>
            <if test="tagColor != null">tag_color,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="status != null">status,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="tagName != null and tagName != ''">#{tagName},</if>
            <if test="tagColor != null">#{tagColor},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="status != null">#{status},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updatePortalCustomerTag" parameterType="com.raisetech.portal.domain.PortalCustomerTag">
        update portal_customer_tag
        <set>
            <if test="tagName != null and tagName != ''">tag_name = #{tagName},</if>
            <if test="tagColor != null">tag_color = #{tagColor},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where tag_id = #{tagId}
    </update>

    <delete id="deletePortalCustomerTagByTagId" parameterType="Long">
        update portal_customer_tag set del_flag = '1' where tag_id = #{tagId}
    </delete>

    <delete id="deletePortalCustomerTagByTagIds" parameterType="String">
        update portal_customer_tag set del_flag = '1' where tag_id in
        <foreach item="tagId" collection="array" open="(" separator="," close=")">
            #{tagId}
        </foreach>
    </delete>

</mapper>
