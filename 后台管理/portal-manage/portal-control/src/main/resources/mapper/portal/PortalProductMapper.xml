        <result property="createTime"     column="create_time"          />
        <result property="updateBy"       column="update_by"            />
        <result property="updateTime"     column="update_time"          />
        <result property="remark"         column="remark"               />
    </resultMap>

    <sql id="selectPortalProductVo">
        select p.product_id, p.product_code, p.product_name, p.category_id,
               c.category_name, p.brand_id, b.brand_name, p.main_image,
               p.thumbnail_image, p.video_url, p.sub_title, p.summary,
               p.description, p.price, p.original_price, p.cost_price,
               p.unit, p.weight, p.volume, p.sales_count, p.view_count,
               p.collect_count, p.comment_count, p.sku_count, p.is_recommend,
               p.is_new, p.is_hot, p.status, p.sort_order, p.publish_time,
               p.del_flag, p.create_by, p.create_time, p.update_by,
               p.update_time, p.remark
        from portal_product p
        left join portal_product_category c on p.category_id = c.category_id
        left join portal_product_brand b on p.brand_id = b.brand_id
    </sql>

    <select id="selectPortalProductList" parameterType="com.raisetech.portal.domain.PortalProduct" resultMap="PortalProductResult">
        <include refid="selectPortalProductVo"/>
        <where>
            p.del_flag = '0'
            <if test="productName != null and productName != ''">
                and p.product_name like concat('%', #{productName}, '%')
            </if>
            <if test="productCode != null and productCode != ''">
                and p.product_code like concat('%', #{productCode}, '%')
            </if>
            <if test="categoryId != null">
                and p.category_id = #{categoryId}
            </if>
            <if test="brandId != null">
                and p.brand_id = #{brandId}
            </if>
            <if test="status != null and status != ''">
                and p.status = #{status}
            </if>
            <if test="isRecommend != null and isRecommend != ''">
                and p.is_recommend = #{isRecommend}
            </if>
            <if test="isNew != null and isNew != ''">
                and p.is_new = #{isNew}
            </if>
            <if test="isHot != null and isHot != ''">
                and p.is_hot = #{isHot}
            </if>
            <if test="params.beginTime != null and params.beginTime != ''">
                and date_format(p.publish_time,'%y%m%d') &gt;= date_format(#{params.beginTime},'%y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                and date_format(p.publish_time,'%y%m%d') &lt;= date_format(#{params.endTime},'%y%m%d')
            </if>
        </where>
        order by p.sort_order asc, p.product_id desc
    </select>

    <select id="selectPortalProductByProductId" parameterType="Long" resultMap="PortalProductResult">
        <include refid="selectPortalProductVo"/>
        where p.product_id = #{productId}
    </select>

