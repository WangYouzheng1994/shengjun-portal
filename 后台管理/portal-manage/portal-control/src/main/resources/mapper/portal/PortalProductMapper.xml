    <delete id="deletePortalProductByProductId" parameterType="Long">
        update portal_product set del_flag = '1' where product_id = #{productId}
    </delete>

    <delete id="deletePortalProductByProductIds" parameterType="String">
        update portal_product set del_flag = '1' where product_id in
        <foreach item="productId" collection="array" open="(" separator="," close=")">
            #{productId}
        </foreach>
