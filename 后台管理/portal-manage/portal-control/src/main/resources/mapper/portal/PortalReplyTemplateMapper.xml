<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.raisetech.portal.mapper.PortalReplyTemplateMapper">

    <resultMap type="PortalReplyTemplate" id="PortalReplyTemplateResult">
        <result property="templateId"      column="template_id"        />
        <result property="templateName"    column="template_name"      />
        <result property="templateContent" column="template_content"   />
        <result property="templateType"    column="template_type"      />
        <result property="status"          column="status"            />
        <result property="useCount"        column="use_count"          />
        <result property="delFlag"         column="del_flag"           />
        <result property="createBy"        column="create_by"          />
        <result property="createTime"      column="create_time"        />
        <result property="updateBy"        column="update_by"          />
        <result property="updateTime"      column="update_time"        />
        <result property="remark"          column="remark"             />
    </resultMap>

    <sql id="selectPortalReplyTemplateVo">
        select template_id, template_name, template_content, template_type,
               status, use_count, del_flag, create_by, create_time,
               update_by, update_time, remark
        from portal_message_template
    </sql>

    <select id="selectPortalReplyTemplateList" parameterType="PortalReplyTemplate" resultMap="PortalReplyTemplateResult">
        <include refid="selectPortalReplyTemplateVo"/>
        <where>
            del_flag = '0'
            <if test="templateName != null and templateName != ''">
                and template_name like concat('%', #{templateName}, '%')
            </if>
            <if test="templateType != null and templateType != ''">
                and template_type = #{templateType}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="selectPortalReplyTemplateByTemplateId" parameterType="Long" resultMap="PortalReplyTemplateResult">
        <include refid="selectPortalReplyTemplateVo"/>
        where template_id = #{templateId} and del_flag = '0'
    </select>

    <insert id="insertPortalReplyTemplate" parameterType="PortalReplyTemplate" useGeneratedKeys="true" keyProperty="templateId">
        insert into portal_message_template
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="templateName != null and templateName != ''">template_name,</if>
            <if test="templateContent != null">template_content,</if>
            <if test="templateType != null">template_type,</if>
            <if test="status != null">status,</if>
            <if test="useCount != null">use_count,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="templateName != null and templateName != ''">#{templateName},</if>
            <if test="templateContent != null">#{templateContent},</if>
            <if test="templateType != null">#{templateType},</if>
            <if test="status != null">#{status},</if>
            <if test="useCount != null">#{useCount},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updatePortalReplyTemplate" parameterType="PortalReplyTemplate">
        update portal_message_template
        <set>
            <if test="templateName != null and templateName != ''">template_name = #{templateName},</if>
            <if test="templateContent != null">template_content = #{templateContent},</if>
            <if test="templateType != null">template_type = #{templateType},</if>
            <if test="status != null">status = #{status},</if>
            <if test="useCount != null">use_count = #{useCount},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where template_id = #{templateId}
    </update>

    <delete id="deletePortalReplyTemplateByTemplateId" parameterType="Long">
        update portal_message_template set del_flag = '1' where template_id = #{templateId}
    </delete>

    <delete id="deletePortalReplyTemplateByTemplateIds" parameterType="String">
        update portal_message_template set del_flag = '1' where template_id in
        <foreach item="templateId" collection="array" open="(" separator="," close=")">
            #{templateId}
        </foreach>
    </delete>

</mapper>
