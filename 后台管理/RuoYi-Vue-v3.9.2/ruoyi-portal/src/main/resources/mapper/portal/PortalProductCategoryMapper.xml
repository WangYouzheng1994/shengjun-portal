<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.portal.mapper.PortalProductCategoryMapper">

    <resultMap type="com.ruoyi.portal.domain.PortalProductCategory" id="PortalProductCategoryResult">
        <result property="categoryId"     column="category_id"     />
        <result property="categoryName"   column="category_name"   />
        <result property="categoryCode"   column="category_code"   />
        <result property="parentId"       column="parent_id"       />
        <result property="ancestors"      column="ancestors"        />
        <result property="icon"           column="icon"             />
        <result property="image"          column="image"            />
        <result property="keywords"       column="keywords"         />
        <result property="description"    column="description"      />
        <result property="templateId"     column="template_id"      />
        <result property="sortOrder"      column="sort_order"        />
        <result property="status"         column="status"            />
        <result property="delFlag"        column="del_flag"          />
        <result property="createBy"       column="create_by"         />
        <result property="createTime"     column="create_time"       />
        <result property="updateBy"       column="update_by"         />
        <result property="updateTime"     column="update_time"       />
        <result property="remark"         column="remark"             />
    </resultMap>

    <sql id="selectPortalProductCategoryVo">
        select category_id, category_name, category_code, parent_id,
               ancestors, icon, image, keywords, description, template_id,
               sort_order, status, del_flag, create_by, create_time,
               update_by, update_time, remark
        from portal_product_category
    </sql>

    <select id="selectPortalProductCategoryList" parameterType="com.ruoyi.portal.domain.PortalProductCategory" resultMap="PortalProductCategoryResult">
        <include refid="selectPortalProductCategoryVo"/>
        <where>
            del_flag = '0'
            <if test="categoryName != null and categoryName != ''">
                and category_name like concat('%', #{categoryName}, '%')
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
            <if test="parentId != null">
                and parent_id = #{parentId}
            </if>
        </where>
        order by sort_order asc, category_id asc
    </select>

    <select id="selectPortalProductCategoryTree" parameterType="com.ruoyi.portal.domain.PortalProductCategory" resultMap="PortalProductCategoryResult">
        <include refid="selectPortalProductCategoryVo"/>
        <where>
            del_flag = '0'
            <if test="categoryName != null and categoryName != ''">
                and category_name like concat('%', #{categoryName}, '%')
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by sort_order asc, category_id asc
    </select>

    <select id="selectPortalProductCategoryByCategoryId" parameterType="Long" resultMap="PortalProductCategoryResult">
        <include refid="selectPortalProductCategoryVo"/>
        where category_id = #{categoryId}
    </select>

    <insert id="insertPortalProductCategory" parameterType="com.ruoyi.portal.domain.PortalProductCategory" useGeneratedKeys="true" keyProperty="categoryId">
        insert into portal_product_category
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="categoryName != null and categoryName != ''">category_name,</if>
            <if test="categoryCode != null and categoryCode != ''">category_code,</if>
            <if test="parentId != null">parent_id,</if>
            <if test="ancestors != null">ancestors,</if>
            <if test="icon != null">icon,</if>
            <if test="image != null">image,</if>
            <if test="keywords != null">keywords,</if>
            <if test="description != null">description,</if>
            <if test="templateId != null">template_id,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="status != null">status,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="categoryName != null and categoryName != ''">#{categoryName},</if>
            <if test="categoryCode != null and categoryCode != ''">#{categoryCode},</if>
            <if test="parentId != null">#{parentId},</if>
            <if test="ancestors != null">#{ancestors},</if>
            <if test="icon != null">#{icon},</if>
            <if test="image != null">#{image},</if>
            <if test="keywords != null">#{keywords},</if>
            <if test="description != null">#{description},</if>
            <if test="templateId != null">#{templateId},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="status != null">#{status},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updatePortalProductCategory" parameterType="com.ruoyi.portal.domain.PortalProductCategory">
        update portal_product_category
        <set>
            <if test="categoryName != null and categoryName != ''">category_name = #{categoryName},</if>
            <if test="categoryCode != null and categoryCode != ''">category_code = #{categoryCode},</if>
            <if test="icon != null">icon = #{icon},</if>
            <if test="image != null">image = #{image},</if>
            <if test="keywords != null">keywords = #{keywords},</if>
            <if test="description != null">description = #{description},</if>
            <if test="templateId != null">template_id = #{templateId},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where category_id = #{categoryId}
    </update>

    <delete id="deletePortalProductCategoryByCategoryId" parameterType="Long">
        update portal_product_category set del_flag = '1' where category_id = #{categoryId}
    </delete>

    <delete id="deletePortalProductCategoryByCategoryIds" parameterType="String">
        update portal_product_category set del_flag = '1' where category_id in
        <foreach item="categoryId" collection="array" open="(" separator="," close=")">
            #{categoryId}
        </foreach>
    </delete>

</mapper>
